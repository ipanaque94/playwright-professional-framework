# Environment
TEST_ENV=LOCAL
NODE_ENV=development

# URLs
BASE_URL=https://thefreerangetester.github.io/sandbox-automation-testing/
API_BASE_URL=https://jsonplaceholder.typicode.com

# Timeouts
DEFAULT_TIMEOUT=30000
API_TIMEOUT=10000

# Retry
MAX_RETRIES=2

# Reporting
ENABLE_LOGGING=true
LOG_LEVEL=INFO
```

## **Paso 1.5: .gitignore**
```
node_modules/
dist/
test-results/
playwright-report/
playwright/.cache/
reports/
screenshots/
logs/
*.log
.env
.DS_Store
package-lock.json