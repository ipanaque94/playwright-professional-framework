{
  "name": "playwright-professional-complete",
  "version": "1.0.0",
  "description": "Complete Professional Playwright Testing Framework with POM, Helpers, and All Test Types",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-tests",
    "test:api": "playwright test --project=api-tests",
    "test:e2e": "playwright test --project=e2e-tests",
    "test:integration": "playwright test --project=integration-tests",
    "test:contract": "playwright test --project=contract-tests",
    "test:performance": "playwright test --project=performance-tests",
    "test:security": "playwright test --project=security-tests",
    "test:accessibility": "playwright test --project=accessibility-tests",
    "test:visual": "playwright test --project=visual-tests",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report reports/html-report --port=9324",
    "update-snapshots": "playwright test --update-snapshots"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "qa",
    "automation",
    "professional",
    "pom",
    "page-object-model"
  ],
  "author": "Enoc Ipanaque",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@axe-core/playwright": "^4.8.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.0"
  }
}